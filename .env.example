# 本番(Render)で設定する環境変数の見本。
# ローカル開発では未設定でOK（自動でファイルDB + 仮パスワード "myday" になる）。

# ログインのパスワード（あなただけが知っている文字列に）
APP_PASSWORD=

# クッキー署名用のランダムな長い文字列。生成例:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Turso のデータベース接続情報（Tursoで作成後にコピー）
DATABASE_URL=
DATABASE_AUTH_TOKEN=

# リモートMCP（スマホのClaude連携）用トークン。生成例:
#   node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
# コネクターURL: https://<あなたのapp>.onrender.com/mcp/<MCP_TOKEN>
MCP_TOKEN=

# 本番では production にする（Renderのrender.yamlで自動設定済み）
NODE_ENV=production
